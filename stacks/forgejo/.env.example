# Forgejo Environment Configuration
# Service: Forgejo (Self-hosted Git Forge)
# VM: TBD
# Generated: 2026-03-04
# Documentation: https://forgejo.org/docs/latest/admin/installation/docker/

# ==============================================================================
# SECRETS - Store in Vaultwarden
# ==============================================================================
# Vaultwarden path: vm-XXX/forgejo-secrets
# Retrieve using: bw get item forgejo-secrets --field postgres_password

# PostgreSQL Password
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=PLACEHOLDER_RETRIEVE_FROM_VAULTWARDEN

# ==============================================================================
# USER/GROUP IDS (Rootless Image)
# ==============================================================================
# The rootless image requires explicit UID/GID configuration.
# Directory ownership must match these values before first start.
# Run: chown -R 1000:1000 /mnt/jace_coda/projects/infinitynode.ai/forgejo

PUID=1000
PGID=1000

# ==============================================================================
# SERVER SETTINGS
# ==============================================================================

# Application name displayed in the UI
APP_NAME=Forgejo

# External domain (for web access)
DOMAIN=forgejo.infinity-node.com

# SSH domain (for git clone URLs)
SSH_DOMAIN=forgejo.infinity-node.com

# Full root URL (include protocol)
ROOT_URL=https://forgejo.infinity-node.com

# ==============================================================================
# PORT CONFIGURATION
# ==============================================================================

# Web interface port (maps to container port 3000)
WEB_PORT=3010

# SSH port for Git operations (maps to container port 2222)
SSH_PORT=222

# ==============================================================================
# DATA STORAGE
# ==============================================================================

# Base path for all Forgejo data (repos, config, database)
DATA_PATH=/mnt/jace_coda/projects/infinitynode.ai/forgejo

# ==============================================================================
# OPTIONAL SETTINGS
# ==============================================================================

# Disable registration after initial setup
# FORGEJO__service__DISABLE_REGISTRATION=true

# Require sign-in to view anything
# FORGEJO__service__REQUIRE_SIGNIN_VIEW=true

# Enable/disable OpenID Connect sign-in
# FORGEJO__openid__ENABLE_OPENID_SIGNIN=false

# LFS (Large File Storage) settings
# FORGEJO__server__LFS_START_SERVER=true

# ==============================================================================
# DEPLOYMENT NOTES
# ==============================================================================
#
# 1. Create data directories with correct ownership:
#    sudo mkdir -p /mnt/jace_coda/projects/infinitynode.ai/forgejo/{data,config,postgres}
#    sudo chown -R 1000:1000 /mnt/jace_coda/projects/infinitynode.ai/forgejo
#
# 2. Generate and store PostgreSQL password in Vaultwarden:
#    openssl rand -base64 24
#
# 3. Copy this file to .env and fill in secrets:
#    cp .env.example .env
#
# 4. Start the stack:
#    docker compose up -d
#
# 5. Access web UI at http://localhost:3010 (or via reverse proxy)
#
# 6. Complete initial setup wizard in browser

# ==============================================================================
# TRAEFIK CONFIGURATION
# ==============================================================================
# Add to your Traefik dynamic config:
#
# http:
#   routers:
#     forgejo:
#       rule: "Host(`forgejo.infinity-node.com`)"
#       service: forgejo
#       entryPoints:
#         - websecure
#       tls:
#         certResolver: letsencrypt
#     forgejo-local:
#       rule: "Host(`forgejo.local.infinity-node.win`)"
#       service: forgejo
#       entryPoints:
#         - websecure
#       tls: {}
#   services:
#     forgejo:
#       loadBalancer:
#         servers:
#           - url: "http://forgejo:3000"

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
#
# - The rootless image is more secure (runs as non-root)
# - SSH keys are stored in DATA_PATH/data/git/.ssh/
# - Consider disabling registration after creating your account
# - POSTGRES_PASSWORD should be strong and stored in Vaultwarden
